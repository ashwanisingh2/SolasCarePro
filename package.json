{
  "name": "solas-system-care-pro",
  "version": "2.0.0",
  "description": "Professional-grade Advanced System Repair & Driver Management Suite",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "electron .",
    "build": "vite build && electron-builder",
    "vite:build": "vite build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "package-app": "vite build && electron-packager . SolasSystemCarePro --platform=win32 --arch=x64 --overwrite --out=dist-win"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.solas.systemcarepro",
    "productName": "SolasSystemCarePro",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "scripts/**/*"
    ],
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "requireAdministrator"
    }
  }
}
