{
  "name": "solas-care-pro",
  "version": "5.1.0",
  "description": "SolasCare Pro — Personal IT Administrator for Windows. 10-feature Brain.md implementation: Surgical Uninstaller, Workspace Automation, God Mode Tweaker, Software Forge, Privacy Blackhole, Solas Vault, Micro-Snapshots, PC Clone, Predictive Maintenance, Solas Sentinel.",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/SPTL-Solas/SolasCarePro"
  },
  "author": "SolasCare",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:prod && electron-builder",
    "build:prod": "cross-env NODE_ENV=production vite build",
    "build:dev": "vite build",
    "vite:build": "vite build",
    "pack": "electron-builder --dir",
    "prebuild": "npm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ electron/ main.js preload.js test/ --ext .js,.jsx",
    "lint:fix": "eslint src/ electron/ main.js preload.js test/ --ext .js,.jsx --fix"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^24.0.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.49.0",
    "vite": "^5.1.4",
    "vitest": "^1.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.solas.carepro",
    "productName": "SolasCare Pro",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "electron/**/*",
      "scripts/**/*",
      "icon.png"
    ],
    "asar": true,
    "asarUnpack": [
      "scripts/**/*"
    ],
    "win": {
      "icon": "icon.png",
      "publisherName": "SolasCare",
      "target": [
        "portable",
        "zip",
        "nsis"
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "include": "build/installer.nsh"
    }
  }
}
