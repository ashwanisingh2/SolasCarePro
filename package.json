{
  "name": "solas-care-pro",
  "version": "4.3.0",
  "description": "Professional-grade Advanced System Repair & Driver Management Suite",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build && electron-builder",
    "vite:build": "vite build",
    "pack": "electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "jsdom": "^24.0.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.35",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^1.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.solas.carepro",
    "productName": "SolasCare Pro",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "electron/**/*",
      "scripts/**/*",
      "icon.png"
    ],
    "asar": true,
    "asarUnpack": [
      "scripts/**/*"
    ],
    "win": {
      "icon": "icon.png",
      "target": [
        "portable",
        "zip",
        "nsis"
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "include": "build/installer.nsh"
    }
  }
}
