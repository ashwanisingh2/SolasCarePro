<UserControl x:Class="SolasCareWpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:SolasCareWpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- Header -->
                <TextBlock Text="System Dashboard" Style="{StaticResource MaterialDesignHeadline4TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,0,0,24"/>

                <!-- Top Section: Circular Health Indicator -->
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B">
                    <Grid Height="200">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Circular Gauge -->
                        <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar x:Name="HealthProgress"
                                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Value="{Binding HealthScore}"
                                         Minimum="0" Maximum="100"
                                         Width="140" Height="140"
                                         Foreground="{Binding HealthColor}"
                                         Background="#334155"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HealthScore, StringFormat={}{0}%}" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="PC Health" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Health Summary Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="Your PC Health Status" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="Some system items require optimization to recover performance. Run a smart scan to clean junk files, repair registry entries, and protect privacy details." 
                                       Style="{StaticResource MaterialDesignBody2TextBlock}" Foreground="#94A3B8" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,16"/>
                            <Button Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                    Command="{Binding QuickActionCommand}" CommandParameter="scan"
                                    Background="#8B5CF6" BorderBrush="#8B5CF6" Foreground="White"
                                    HorizontalAlignment="Left" Padding="16,8" Height="Auto">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Magnify" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Run Smart Scan Now" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Middle Section: Quick Action Cards -->
                <TextBlock Text="Quick Optimization Tools" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,8,0,16"/>
                
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <!-- Card 1: 1-Click Optimizer -->
                    <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,12,0" Background="#1E293B">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="Flash" Foreground="#06B6D4" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Smart Optimizer" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="Quickly scan your entire system, clean temp storage, repair registry links, and boost memory instantly." 
                                       Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="12"/>
                            <Button Grid.Row="2" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                    Command="{Binding QuickActionCommand}" CommandParameter="scan"
                                    BorderBrush="#8B5CF6" Foreground="White" Content="Launch Optimizer" Height="36"/>
                        </Grid>
                    </Border>

                    <!-- Card 2: Fix Registry Errors -->
                    <Border Style="{StaticResource GlassPanelStyle}" Margin="6,0,6,0" Background="#1E293B">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="FileCabinet" Foreground="#FBBF24" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="System Repair" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="Scan system files integrity (SFC) and repair component stores (DISM) to fix system crashes and freezes." 
                                       Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="12"/>
                            <Button Grid.Row="2" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                    Command="{Binding QuickActionCommand}" CommandParameter="registry"
                                    BorderBrush="#8B5CF6" Foreground="White" Content="Repair Files" Height="36"/>
                        </Grid>
                    </Border>

                    <!-- Card 3: Remove Junk -->
                    <Border Style="{StaticResource GlassPanelStyle}" Margin="12,0,0,0" Background="#1E293B">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="TrashCan" Foreground="#F87171" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Junk Cleaner" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="Clean temporary directories, system caches, browser logs, and recover gigabytes of valuable storage." 
                                       Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,0,0,16" FontSize="12"/>
                            <Button Grid.Row="2" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                    Command="{Binding QuickActionCommand}" CommandParameter="junk"
                                    BorderBrush="#8B5CF6" Foreground="White" Content="Clean Storage" Height="36"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- Bottom Section: System Live Stats -->
                <TextBlock Text="System Resources Monitor" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,8,0,16"/>
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- CPU -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="CPU Usage" Foreground="White" FontWeight="Bold" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding CpuUsage}" Foreground="#8B5CF6" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Grid.Row="1" Value="{Binding CpuValue}" Minimum="0" Maximum="100" Height="8" Foreground="#8B5CF6" Background="#334155" />
                        </Grid>

                        <!-- RAM -->
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="RAM Memory Usage" Foreground="White" FontWeight="Bold" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding RamUsage}" Foreground="#06B6D4" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Grid.Row="1" Value="{Binding RamValue}" Minimum="0" Maximum="100" Height="8" Foreground="#06B6D4" Background="#334155" />
                        </Grid>

                        <!-- Disk Space -->
                        <Grid Grid.Row="2" Margin="0,0,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="Disk Space Used (C:)" Foreground="White" FontWeight="Bold" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding DiskFreeSpace}" Foreground="#34D399" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Grid.Row="1" Value="{Binding DiskValue}" Minimum="0" Maximum="100" Height="8" Foreground="#34D399" Background="#334155" />
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
