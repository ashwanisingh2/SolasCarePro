<UserControl x:Class="SolasCareWpf.Views.SystemRepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:SolasCareWpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="Transparent" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="System File Repair &amp; Health" Style="{StaticResource MaterialDesignHeadline4TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Content Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Actions Panel -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- SFC Card -->
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="ShieldCheck" Foreground="#06B6D4" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="System File Checker" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Verifies system files and replaces corrupted files with clean cached copies." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                Command="{Binding RunSfcScanCommand}"
                                IsEnabled="{Binding IsRepairing, Converter={StaticResource InverseBoolConverter}}"
                                Background="#8B5CF6" BorderBrush="#8B5CF6" Foreground="White" Height="32">
                            <TextBlock Text="Run SFC Check" FontSize="11" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- DISM Card -->
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="ServerSecurity" Foreground="#FBBF24" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="DISM Component Store" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Scans and repairs local Windows system image and component store metadata." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                Command="{Binding RunDismScanCommand}"
                                IsEnabled="{Binding IsRepairing, Converter={StaticResource InverseBoolConverter}}"
                                Background="#8B5CF6" BorderBrush="#8B5CF6" Foreground="White" Height="32">
                            <TextBlock Text="Run DISM Repair" FontSize="11" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- One-click Restore + Repair -->
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Complete System Repair" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Creates a Restore Point and performs both SFC and DISM verification routines automatically." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                Command="{Binding RunFullSystemRepairCommand}"
                                IsEnabled="{Binding IsRepairing, Converter={StaticResource InverseBoolConverter}}"
                                Background="#34D399" BorderBrush="#34D399" Foreground="#0F172A" Height="36">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="WrenchOutline" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Full Repair System" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Logs and Progress Monitor Panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Busy Progress indicator -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding ProgressValue}" Minimum="0" Maximum="100" Height="8" Foreground="#8B5CF6" Background="#334155"/>
                </StackPanel>

                <!-- Status Header -->
                <TextBlock Grid.Row="1" Text="Execution Log Output" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="0,4,0,8"/>

                <!-- Logs Box -->
                <Border Grid.Row="2" Background="#0B0F19" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding RepairLogs, Mode=OneWay}"
                                 Foreground="#34D399"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
