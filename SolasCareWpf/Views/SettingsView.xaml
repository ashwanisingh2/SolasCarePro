<UserControl x:Class="SolasCareWpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:SolasCareWpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="Transparent" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Application Settings" Style="{StaticResource MaterialDesignHeadline4TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                
                <!-- General Preferences -->
                <TextBlock Text="General Preferences" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,0,0,12"/>
                
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B">
                    <StackPanel>
                        <!-- Theme switch -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Dark Theme Mode" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Toggle application skin to dark navy theme layout." Foreground="#94A3B8" FontSize="11"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsDarkTheme}" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="#334155" Margin="0,0,0,16"/>

                        <!-- Auto Backup Registry -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Automatic Safety Backup" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Export specific registry key snapshots into backups (.reg) before making edits." Foreground="#94A3B8" FontSize="11"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding AutoBackupBeforeRepair}" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Safety Restore Point Creation -->
                <TextBlock Text="Windows System Restore" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,8,0,12"/>

                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B">
                    <StackPanel>
                        <TextBlock Text="Create System Restore Point" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Configure a manual checkpoint in Windows. You can roll back settings later if troubleshooting is needed." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        
                        <!-- Description Input -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding RestorePointDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Checkpoint Description"
                                     Foreground="White"
                                     BorderBrush="#475569"
                                     CaretBrush="#8B5CF6"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding RestorePointStatusText}" Foreground="#06B6D4" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0"/>
                            <Button Grid.Column="1" Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                    Command="{Binding CreateManualRestorePointCommand}"
                                    IsEnabled="{Binding IsCreatingRestorePoint, Converter={StaticResource InverseBoolConverter}}"
                                    Background="#8B5CF6" BorderBrush="#8B5CF6" Foreground="White" Padding="16,8" Height="Auto" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Value="0" Width="16" Height="16" Foreground="White" Margin="0,0,8,0" Visibility="{Binding IsCreatingRestorePoint, Converter={StaticResource BoolToVis}}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Create Point" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Software Details -->
                <TextBlock Text="About SolasCarePro Desktop" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,8,0,12"/>
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Application Version" Foreground="#94A3B8" FontSize="12"/>
                            <TextBlock Text="v2.5.0 Premium" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Architecture Platform" Foreground="#94A3B8" FontSize="12"/>
                            <TextBlock Text="WPF Desktop (.NET 8.0-windows x64)" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Developer Studio" Foreground="#94A3B8" FontSize="12"/>
                            <TextBlock Text="ashwanisingh2/SolasCarePro" Foreground="#8B5CF6" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
