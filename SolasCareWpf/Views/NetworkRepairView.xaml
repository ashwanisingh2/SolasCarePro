<UserControl x:Class="SolasCareWpf.Views.NetworkRepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:SolasCareWpf.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="Transparent" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Network &amp; Adapter Repair" Style="{StaticResource MaterialDesignHeadline4TextBlock}" Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Main Body Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Diagnostic actions sidebar -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- DNS Flush Block -->
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="Web" Foreground="#06B6D4" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Flush DNS Cache" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Clears Windows hostname resolver cache to fix invalid address mappings." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                Command="{Binding FlushDnsCommand}"
                                IsEnabled="{Binding IsRepairing, Converter={StaticResource InverseBoolConverter}}"
                                Background="#8B5CF6" BorderBrush="#8B5CF6" Foreground="White" Height="32">
                            <TextBlock Text="Flush Resolver Cache" FontSize="11" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Winsock Reset Block -->
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="Network" Foreground="#FBBF24" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reset Winsock Catalog" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Restores Windows Sockets configurations back to initial system defaults." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                Command="{Binding ResetWinsockCommand}"
                                IsEnabled="{Binding IsRepairing, Converter={StaticResource InverseBoolConverter}}"
                                Background="#8B5CF6" BorderBrush="#8B5CF6" Foreground="White" Height="32">
                            <TextBlock Text="Reset Winsock API" FontSize="11" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Comprehensive Fix Block -->
                <Border Style="{StaticResource GlassPanelStyle}" Background="#1E293B" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Full Network Overhaul" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Cleans DNS cache, resets Winsock sockets, and clears IPv4/IPv6 interface routes." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button Style="{StaticResource MaterialDesignFlatMidPrimaryButton}"
                                Command="{Binding RepairAllNetworkCommand}"
                                IsEnabled="{Binding IsRepairing, Converter={StaticResource InverseBoolConverter}}"
                                Background="#34D399" BorderBrush="#34D399" Foreground="#0F172A" Height="36">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="NetworkStrength4" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Repair Network Adapters" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Progress monitor and console outputs -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Progress -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding ProgressValue}" Minimum="0" Maximum="100" Height="8" Foreground="#8B5CF6" Background="#334155"/>
                </StackPanel>

                <!-- Text label -->
                <TextBlock Grid.Row="1" Text="Network Command Log Details" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="0,4,0,8"/>

                <!-- Logs TextBox -->
                <Border Grid.Row="2" Background="#0B0F19" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding NetworkLogs, Mode=OneWay}"
                                 Foreground="#34D399"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
