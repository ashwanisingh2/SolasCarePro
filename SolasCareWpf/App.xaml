<Application x:Class="SolasCareWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:SolasCareWpf"
             xmlns:converters="clr-namespace:SolasCareWpf.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Cyan" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />

            <!-- Custom Brushes and Colors based on styling rules -->
            <SolidColorBrush x:Key="BrandNavyBrush" Color="#0F172A" />
            <SolidColorBrush x:Key="Slate950Brush" Color="#0B0F19" />
            <SolidColorBrush x:Key="Slate900Brush" Color="#0F172A" />
            <SolidColorBrush x:Key="Slate800Brush" Color="#1E293B" />
            <SolidColorBrush x:Key="Slate700Brush" Color="#334155" />
            <SolidColorBrush x:Key="BrandVioletBrush" Color="#8B5CF6" />
            <SolidColorBrush x:Key="BrandCyanBrush" Color="#06B6D4" />
            
            <!-- Alert States Brushes -->
            <SolidColorBrush x:Key="SuccessGreenBrush" Color="#34D399" />
            <SolidColorBrush x:Key="WarningAmberBrush" Color="#FBBF24" />
            <SolidColorBrush x:Key="DangerRoseBrush" Color="#F87171" />
            
            <!-- Glass Panel Style -->
            <Style x:Key="GlassPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="#1E293B" />
                <Setter Property="BorderBrush" Value="#475569" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>

            <!-- Menu Button Style -->
            <Style x:Key="MenuButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
                <Setter Property="Height" Value="48"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" CornerRadius="8" Padding="12,0">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#334155"/>
                                    <Setter Property="Foreground" Value="#8B5CF6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
