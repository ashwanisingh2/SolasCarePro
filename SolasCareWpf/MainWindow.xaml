<Window x:Class="SolasCareWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:SolasCareWpf"
        xmlns:viewmodels="clr-namespace:SolasCareWpf.ViewModels"
        xmlns:views="clr-namespace:SolasCareWpf.Views"
        mc:Ignorable="d"
        Title="SolasCarePro System Repair Utility" 
        Height="650" Width="1050"
        Background="#0F172A"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Mapping ViewModels to UserControls (Views) -->
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SmartScanViewModel}">
            <views:SmartScanView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SystemRepairViewModel}">
            <views:SystemRepairView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:JunkCleanerViewModel}">
            <views:JunkCleanerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SpeedBoosterViewModel}">
            <views:SpeedBoosterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:NetworkRepairViewModel}">
            <views:NetworkRepairView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar Navigation -->
            <ColumnDefinition Width="260"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- A. Left Sidebar -->
        <Border Grid.Column="0" Background="#0B0F19" BorderBrush="#1E293B" BorderThickness="0,0,1,0">
            <Grid Margin="16,24,16,16">
                <Grid.RowDefinitions>
                    <!-- Brand / Logo -->
                    <RowDefinition Height="Auto"/>
                    <!-- Menu Navigation Links -->
                    <RowDefinition Height="*"/>
                    <!-- Bottom Pro Lock / Version -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand / Logo Section -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                    <materialDesign:PackIcon Kind="ShieldLock" Foreground="#8B5CF6" Width="36" Height="36" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="SOLAS CARE" Foreground="White" FontWeight="Bold" FontSize="18"/>
                        <TextBlock Text="System Optimizer" Foreground="#06B6D4" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation List -->
                <StackPanel Grid.Row="1">
                    <!-- Dashboard -->
                    <RadioButton Style="{StaticResource MenuButtonStyle}"
                                 IsChecked="True"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Smart Scan -->
                    <RadioButton Style="{StaticResource MenuButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Smart Scan">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Smart Scan" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- System Repair -->
                    <RadioButton Style="{StaticResource MenuButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="System Repair">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Wrench" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="System Repair" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Junk Cleaner -->
                    <RadioButton Style="{StaticResource MenuButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Junk Files">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TrashCan" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Junk Files Cleaner" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Speed Booster -->
                    <RadioButton Style="{StaticResource MenuButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Speed Booster">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LightningBolt" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Speed Booster" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Network Repair -->
                    <RadioButton Style="{StaticResource MenuButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Network Repair">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="NetworkOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Network Repair" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Settings -->
                    <RadioButton Style="{StaticResource MenuButtonStyle}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Settings" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Bottom Pro Version Lock Box -->
                <Border Grid.Row="2" Background="#1E293B" CornerRadius="8" Padding="12" BorderBrush="#334155" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Pro Version Active" Foreground="#06B6D4" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Text="Enterprise Protection" Foreground="#94A3B8" FontSize="10"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="LockOpen" Foreground="#34D399" Width="22" Height="22" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- B. Right Main Content Area -->
        <Border Grid.Column="1" Background="#0F172A">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
